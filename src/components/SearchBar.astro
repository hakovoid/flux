---
---

<div class="search-wrapper group relative">
  <div class="absolute inset-0 rounded-2xl bg-gradient-to-r from-indigo-500/20 via-purple-500/20 to-indigo-500/20 opacity-0 group-focus-within:opacity-100 blur-xl transition-opacity duration-500"></div>
  <div class="relative flex items-center bg-[var(--color-surface-1)] border border-zinc-800 rounded-2xl group-focus-within:border-indigo-500/60 transition-all duration-300 overflow-hidden">
    <div class="pl-4 flex items-center pointer-events-none text-zinc-500 group-focus-within:text-indigo-400 transition-colors duration-300">
      <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </div>
    <input
      id="search-input"
      type="search"
      placeholder="Rechercher un article, une source, un sujet..."
      aria-label="Rechercher un article"
      class="w-full px-3 py-3.5 bg-transparent text-sm text-white placeholder-zinc-500 focus:outline-none focus:placeholder-zinc-400 transition-colors"
    />
    <div class="hidden sm:flex items-center gap-1.5 pr-3">
      <kbd class="px-2 py-1 text-[10px] text-zinc-500 bg-zinc-800/80 rounded-md border border-zinc-700/50 font-mono tracking-wider leading-none">
        /
      </kbd>
    </div>
  </div>
</div>
