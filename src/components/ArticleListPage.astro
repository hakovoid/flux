---
import ArticleCard from './ArticleCard.astro';
import ArticleListItem from './ArticleListItem.astro';
import ArticleListItemCompact from './ArticleListItemCompact.astro';
import SearchBar from './SearchBar.astro';
import CategoryFilter from './CategoryFilter.astro';
import type { Article, FeedType } from '../types/index';

interface Props {
  articles: Article[];
  categories: string[];
  sources: { name: string; slug: string; url: string; categories: string[]; count: number }[];
  types: FeedType[];
  currentPage: number;
  totalPages: number;
  basePath?: string;
}

const { articles, categories, sources, types, currentPage, totalPages, basePath = '' } = Astro.props;

function pageUrl(page: number): string {
  if (basePath) {
    return page === 1 ? `/${basePath}` : `/${basePath}/page/${page}`;
  }
  return page === 1 ? '/' : `/page/${page}`;
}

const searchIndexUrl = basePath ? `/${basePath}/search-index.json` : '/search-index.json';

const pages: (number | string)[] = [];
for (let i = 1; i <= totalPages; i++) {
  if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
    pages.push(i);
  } else if (pages[pages.length - 1] !== '...') {
    pages.push('...');
  }
}
---

<div class="flex flex-col gap-6">
  <!-- Search + Filters -->
  <div class="flex flex-col gap-3 sm:gap-5 p-3 sm:p-5 rounded-2xl bg-[var(--color-surface-1)]/50 border border-[var(--color-border)] backdrop-blur-sm">
    <div class="flex items-center gap-2">
      <div class="flex-1">
        <SearchBar />
      </div>
      <button
        id="toggle-view"
        aria-label="Basculer la vue"
        class="flex items-center justify-center w-11 h-11 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-1)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)] transition-all cursor-pointer shrink-0"
      >
        <svg id="view-grid" class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 8.25V6Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6A2.25 2.25 0 0 1 12.75 3.75h2.25A2.25 2.25 0 0 1 17.25 6v2.25a2.25 2.25 0 0 1-2.25 2.25h-2.25A2.25 2.25 0 0 1 10.5 8.25V6Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 10.5A2.25 2.25 0 0 1 19.5 12.75v2.25a2.25 2.25 0 0 1-2.25 2.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25a2.25 2.25 0 0 1 2.25-2.25h2.25Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12.75a2.25 2.25 0 0 1 2.25-2.25h2.25a2.25 2.25 0 0 1 2.25 2.25v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25v-2.25Z" />
        </svg>
        <svg id="view-list" class="w-[18px] h-[18px] hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" />
        </svg>
        <svg id="view-compact" class="w-[18px] h-[18px] hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 5.25h16.5M3.75 9h16.5M3.75 12.75h16.5M3.75 16.5h16.5M3.75 20.25h16.5" />
        </svg>
      </button>
      <button
        id="toggle-filters"
        aria-label="Afficher les filtres"
        aria-expanded="false"
        aria-controls="filters-panel"
        class="flex items-center justify-center w-11 h-11 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-1)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)] transition-all cursor-pointer shrink-0"
      >
        <svg id="filter-icon-closed" class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" />
        </svg>
        <svg id="filter-icon-open" class="w-[18px] h-[18px] hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div id="filters-panel" class="hidden sm:block overflow-hidden transition-all duration-300">
      <CategoryFilter categories={categories} sources={sources} types={types} />
    </div>
  </div>

<script is:inline>
  document.addEventListener('astro:page-load', function() {
    // View mode toggle (cycles cards → list → compact)
    var viewToggle = document.getElementById('toggle-view');
    var viewGridIcon = document.getElementById('view-grid');
    var viewListIcon = document.getElementById('view-list');
    var viewCompactIcon = document.getElementById('view-compact');

    // Filter toggle
    var filterToggle = document.getElementById('toggle-filters');
    var filterPanel = document.getElementById('filters-panel');
    var filterIconClosed = document.getElementById('filter-icon-closed');
    var filterIconOpen = document.getElementById('filter-icon-open');

    var VIEW_MODES = ['cards', 'list', 'compact'];
    var VIEW_LABELS = { cards: 'Vue cartes', list: 'Vue liste', compact: 'Vue compacte' };

    function applyViewMode(mode) {
      if (VIEW_MODES.indexOf(mode) === -1) mode = 'cards';
      document.documentElement.dataset.viewMode = mode;
      if (viewGridIcon) viewGridIcon.classList.toggle('hidden', mode !== 'cards');
      if (viewListIcon) viewListIcon.classList.toggle('hidden', mode !== 'list');
      if (viewCompactIcon) viewCompactIcon.classList.toggle('hidden', mode !== 'compact');
      if (viewToggle) viewToggle.setAttribute('aria-label', VIEW_LABELS[mode] || 'Basculer la vue');
    }

    var currentViewMode = localStorage.getItem('flux-view-mode') || 'cards';
    applyViewMode(currentViewMode);

    if (viewToggle) {
      viewToggle.onclick = function() {
        var current = document.documentElement.dataset.viewMode || 'cards';
        var nextIndex = (VIEW_MODES.indexOf(current) + 1) % VIEW_MODES.length;
        var next = VIEW_MODES[nextIndex];
        applyViewMode(next);
        localStorage.setItem('flux-view-mode', next);
      };
    }
    
    // Filter panel: persisted open/closed state, default open on desktop / closed on mobile
    var FILTERS_OPEN_KEY = 'flux-filters-open';
    function setFiltersOpen(open) {
      if (!filterPanel) return;
      if (open) {
        filterPanel.classList.remove('hidden');
        filterPanel.classList.add('sm:block');
        if (filterIconClosed) filterIconClosed.classList.add('hidden');
        if (filterIconOpen) filterIconOpen.classList.remove('hidden');
        if (filterToggle) filterToggle.setAttribute('aria-expanded', 'true');
      } else {
        filterPanel.classList.add('hidden');
        filterPanel.classList.remove('sm:block');
        if (filterIconClosed) filterIconClosed.classList.remove('hidden');
        if (filterIconOpen) filterIconOpen.classList.add('hidden');
        if (filterToggle) filterToggle.setAttribute('aria-expanded', 'false');
      }
    }

    var savedFiltersState = localStorage.getItem(FILTERS_OPEN_KEY);
    var filtersInitiallyOpen = savedFiltersState === 'true'
      || (savedFiltersState === null && window.matchMedia('(min-width: 640px)').matches);
    setFiltersOpen(filtersInitiallyOpen);

    if (filterToggle && filterPanel) {
      filterToggle.onclick = function() {
        var nextOpen = filterPanel.classList.contains('hidden');
        setFiltersOpen(nextOpen);
        localStorage.setItem(FILTERS_OPEN_KEY, nextOpen ? 'true' : 'false');
      };
    }
  });
</script>

  <!-- Results count (search/filter mode) -->
  <div id="results-count" class="hidden text-xs text-[var(--color-text-muted)]"></div>

  <!-- Browse mode: static articles -->
  <div id="browse-mode">
    <!-- Cards view -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" data-view-mode="cards">
      {articles.map((article, i) => (
        <ArticleCard article={article} eager={i === 0} />
      ))}
    </div>

    <!-- List view -->
    <div class="flex flex-col gap-3" data-view-mode="list">
      {articles.map((article, i) => (
        <ArticleListItem article={article} eager={i === 0} />
      ))}
    </div>

    <!-- Compact view -->
    <div class="flex flex-col divide-y divide-[var(--color-border)] rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-1)] overflow-hidden" data-view-mode="compact">
      {articles.map((article) => (
        <ArticleListItemCompact article={article} />
      ))}
    </div>

    {articles.length === 0 && (
      <div class="text-center py-20 text-[var(--color-text-muted)]">
        <svg class="w-12 h-12 mx-auto mb-4 text-[var(--color-text-subtle)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" />
        </svg>
        <p class="text-lg font-medium">Aucun article pour le moment</p>
        <p class="text-sm mt-1">Les articles apparaîtront après la première synchronisation RSS.</p>
      </div>
    )}

    {totalPages > 1 && (
      <nav aria-label="Pagination" class="flex items-center justify-center gap-1.5 mt-8">
        {currentPage > 1 && (
          <a href={pageUrl(currentPage - 1)} class="px-3 py-2 text-sm rounded-lg border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)] transition-all" aria-label="Page précédente">←</a>
        )}
        {pages.map((p) => (
          p === '...' ? (
            <span class="px-2 py-2 text-sm text-[var(--color-text-subtle)]">…</span>
          ) : p === currentPage ? (
            <span class="px-3 py-2 text-sm rounded-lg border font-medium accent-pagination-active" aria-current="page">{p}</span>
          ) : (
            <a href={pageUrl(p as number)} class="px-3 py-2 text-sm rounded-lg border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)] transition-all">{p}</a>
          )
        ))}
        {currentPage < totalPages && (
          <a href={pageUrl(currentPage + 1)} class="px-3 py-2 text-sm rounded-lg border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)] transition-all" aria-label="Page suivante">→</a>
        )}
      </nav>
    )}
  </div>

  <!-- Search/filter mode (hidden by default) -->
  <div id="search-mode" class="hidden">
    <!-- Cards view -->
    <div id="search-results" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" data-view-mode="cards"></div>
    <!-- List view -->
    <div id="search-results-list" class="flex flex-col gap-3" data-view-mode="list"></div>
    <!-- Compact view -->
    <div id="search-results-compact" class="flex flex-col divide-y divide-[var(--color-border)] rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-1)] overflow-hidden" data-view-mode="compact"></div>
    <nav id="search-pagination" aria-label="Pagination" class="flex items-center justify-center gap-1.5 mt-8"></nav>
  </div>

  <!-- No results -->
  <div id="no-results" class="hidden text-center py-20 text-[var(--color-text-muted)]">
    <p class="text-lg font-medium">Aucun résultat</p>
    <p class="text-sm mt-1">Essayez avec d'autres termes de recherche.</p>
  </div>
</div>

<script is:inline define:vars={{ searchIndexUrl }}>
  window.__searchIndexUrl = searchIndexUrl;
</script>

<script>
  import Fuse from 'fuse.js';

  const DEFAULT_PAGE_SIZE = 15;
  const PAGE_SIZE_OPTIONS = [15, 30, 50, 100];
  const PAGE_SIZE_KEY = 'flux-page-size';

  function readPageSize(): number {
    try {
      const raw = localStorage.getItem(PAGE_SIZE_KEY);
      if (!raw) return DEFAULT_PAGE_SIZE;
      const n = parseInt(raw, 10);
      return PAGE_SIZE_OPTIONS.includes(n) ? n : DEFAULT_PAGE_SIZE;
    } catch {
      return DEFAULT_PAGE_SIZE;
    }
  }

  interface SearchArticle {
    id: string;
    title: string;
    description: string;
    source: string;
    sourceUrl: string;
    categories: string[];
    pubDate: string;
    image: string;
    link: string;
    type: string;
    audioUrl?: string;
    duration?: string;
  }

  let searchIndex: SearchArticle[] | null = null;
  let fuse: Fuse<SearchArticle> | null = null;

  async function loadSearchIndex(): Promise<SearchArticle[]> {
    if (searchIndex) return searchIndex;
    const res = await fetch((window as any).__searchIndexUrl || '/search-index.json');
    searchIndex = await res.json();
    return searchIndex!;
  }

  const categoryColors: Record<string, string> = {
    Programmation: 'bg-violet-500/20 text-violet-400 border-violet-500/30',
    IA: 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30',
    DevOps: 'bg-orange-500/20 text-orange-400 border-orange-500/30',
    'Cybersécurité': 'bg-red-500/20 text-red-400 border-red-500/30',
    Cloud: 'bg-sky-500/20 text-sky-400 border-sky-500/30',
    Web: 'bg-amber-500/20 text-amber-400 border-amber-500/30',
  };

  const categoryGradients: Record<string, string> = {
    Programmation: 'from-violet-600 to-purple-800',
    IA: 'from-emerald-600 to-teal-800',
    DevOps: 'from-orange-600 to-red-800',
    'Cybersécurité': 'from-red-600 to-rose-800',
    Cloud: 'from-sky-600 to-blue-800',
    Web: 'from-amber-600 to-yellow-800',
  };

  function getCatColor(cat: string): string {
    return categoryColors[cat] || 'bg-zinc-500/20 text-zinc-400 border-zinc-500/30';
  }

  function getCatGradient(cats: string[]): string {
    for (const cat of cats) {
      if (categoryGradients[cat]) return categoryGradients[cat];
    }
    return 'from-zinc-600 to-zinc-800';
  }

  function formatDate(dateStr: string): string {
    return new Date(dateStr).toLocaleDateString('fr-FR', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    });
  }

  function getFreshnessBadge(pubDate: string): { label: string; cls: string } | null {
    const hoursAgo = (Date.now() - new Date(pubDate).getTime()) / (1000 * 60 * 60);
    if (hoursAgo < 24) return { label: 'Nouveau', cls: 'bg-emerald-700 text-white border border-emerald-600 shadow-lg shadow-emerald-700/30' };
    if (hoursAgo < 72) return { label: 'Récent', cls: 'bg-blue-500 text-white border border-blue-400 shadow-lg shadow-blue-500/30' };
    return null;
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function slugify(text: string): string {
    return text
      .normalize('NFD')
      .replace(/[̀-ͯ]/g, '')
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
  }

  function getTypeLabel(type: string): string {
    if (type === 'podcast') return 'Podcast';
    if (type === 'youtube') return 'YouTube';
    return 'Article';
  }

  const FAVORITE_PATH = 'M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.75.75 0 01-.712 0l-.003-.001z';
  const READ_LATER_PATH = 'M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244';

  function readStoredList<T = unknown>(key: string): T[] {
    try {
      const raw = localStorage.getItem('flux-' + key);
      const parsed = raw ? JSON.parse(raw) : [];
      return Array.isArray(parsed) ? parsed : [];
    } catch {
      return [];
    }
  }

  function isFavorited(id: string): boolean {
    return readStoredList<string>('favorites').includes(id);
  }

  function isReadLater(id: string): boolean {
    return readStoredList<{ id: string }>('read-later').some((item) => item && item.id === id);
  }

  function renderActionButtons(id: string, size: 'card' | 'list'): string {
    const fav = isFavorited(id);
    const later = isReadLater(id);
    const favFill = fav ? '#fbbf24' : 'none';
    const laterFill = later ? '#60a5fa' : 'none';

    if (size === 'card') {
      return `<button data-favorite-toggle data-article-id="${escapeHtml(id)}" aria-label="Ajouter aux favoris" class="absolute top-3 right-12 w-7 h-7 flex items-center justify-center rounded-lg bg-[var(--color-surface-overlay)] hover:bg-[var(--color-surface-2)] transition-colors z-10">
        <svg class="w-4 h-4 favorite-icon" fill="${favFill}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path class="favorite-outline" stroke-linecap="round" stroke-linejoin="round" d="${FAVORITE_PATH}" />
        </svg>
      </button>
      <button data-read-later-toggle data-article-id="${escapeHtml(id)}" aria-label="Lire plus tard" class="absolute top-3 right-20 w-7 h-7 flex items-center justify-center rounded-lg bg-[var(--color-surface-overlay)] hover:bg-[var(--color-surface-2)] transition-colors z-10">
        <svg class="w-4 h-4 read-later-icon" fill="${laterFill}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="${READ_LATER_PATH}" />
        </svg>
      </button>`;
    }

    return `<button data-favorite-toggle data-article-id="${escapeHtml(id)}" aria-label="Ajouter aux favoris" class="absolute top-1 right-8 w-6 h-6 flex items-center justify-center rounded-lg bg-[var(--color-surface-overlay)] hover:bg-[var(--color-surface-2)] transition-colors z-10">
      <svg class="w-3 h-3 favorite-icon" fill="${favFill}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path class="favorite-outline" stroke-linecap="round" stroke-linejoin="round" d="${FAVORITE_PATH}" />
      </svg>
    </button>
    <button data-read-later-toggle data-article-id="${escapeHtml(id)}" aria-label="Lire plus tard" class="absolute top-1 right-14 w-6 h-6 flex items-center justify-center rounded-lg bg-[var(--color-surface-overlay)] hover:bg-[var(--color-surface-2)] transition-colors z-10">
      <svg class="w-3 h-3 read-later-icon" fill="${laterFill}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="${READ_LATER_PATH}" />
      </svg>
    </button>`;
  }

  function renderCard(a: SearchArticle): string {
    const badge = getFreshnessBadge(a.pubDate);
    const gradient = getCatGradient(a.categories);

    const catsHtml = a.categories
      .map((c) => `<span class="px-2 py-0.5 text-xs font-medium rounded-full border ${getCatColor(c)}">${escapeHtml(c)}</span>`)
      .join('');

    const imageHtml = a.image
      ? `<img src="${escapeHtml(a.image)}" alt="${escapeHtml(a.title)}" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
         <div class="w-full h-full bg-gradient-to-br ${gradient} items-center justify-center p-5 hidden"><span class="text-sm font-medium text-white/50 line-clamp-3 text-center leading-relaxed">${escapeHtml(a.title)}</span></div>`
      : `<div class="w-full h-full bg-gradient-to-br ${gradient} flex items-center justify-center p-5"><span class="text-sm font-medium text-white/50 line-clamp-3 text-center leading-relaxed">${escapeHtml(a.title)}</span></div>`;

    const badgeHtml = badge
      ? `<span class="absolute top-3 left-3 px-2 py-0.5 text-xs font-medium rounded-full ${badge.cls}">${badge.label}</span>`
      : '';

    const typeBadgeHtml = a.type === 'podcast'
      ? `<span class="absolute bottom-3 right-3 px-2 py-0.5 text-xs font-medium rounded-full border bg-fuchsia-500/20 text-fuchsia-400 border-fuchsia-500/30">Podcast</span>`
      : a.type === 'youtube'
      ? `<span class="absolute bottom-3 right-3 px-2 py-0.5 text-xs font-medium rounded-full border bg-red-500/20 text-red-400 border-red-500/30">YouTube</span>`
      : '';

    return `<article class="card-hover group relative rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-1)] overflow-hidden fade-in-up flex flex-col" data-article-id="${escapeHtml(a.id)}">
      <a href="/article/${escapeHtml(a.id)}" class="block relative aspect-[16/9] overflow-hidden">
        ${imageHtml}
        ${badgeHtml}
        ${typeBadgeHtml}
      </a>
      ${renderActionButtons(a.id, 'card')}
      <div class="p-4 flex flex-col gap-3 flex-1">
        <div class="flex flex-wrap gap-1.5">${catsHtml}</div>
        <h3 class="font-semibold text-sm leading-snug line-clamp-2">
          <a href="/article/${escapeHtml(a.id)}" class="hover:text-[var(--color-accent-400)] transition-colors">${escapeHtml(a.title)}</a>
        </h3>
        <p class="text-xs text-[var(--color-text-secondary)] line-clamp-3 leading-relaxed">${escapeHtml(a.description)}</p>
        <div class="flex items-center justify-between text-xs text-[var(--color-text-secondary)] pt-1">
          <time datetime="${escapeHtml(a.pubDate)}">${formatDate(a.pubDate)}</time>
        </div>
        <a href="${escapeHtml(a.link)}" target="_blank" rel="noopener noreferrer"
           class="flex items-center justify-between gap-3 mt-auto px-3.5 py-2.5 rounded-xl bg-[var(--color-accent-500)]/10 border border-[var(--color-accent-500)]/20 hover:bg-[var(--color-accent-500)]/20 hover:border-[var(--color-accent-500)]/40 transition-all duration-200 group/cta">
          <div class="flex items-center gap-2 min-w-0">
            <div class="w-6 h-6 rounded-lg bg-[var(--color-accent-500)]/20 flex items-center justify-center shrink-0">
              <svg class="w-3 h-3 text-[var(--color-accent-400)]" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
            </div>
            <span class="text-xs font-medium text-[var(--color-accent-300)] truncate">${escapeHtml(a.source)}</span>
          </div>
          <div class="flex items-center gap-1 text-xs text-[var(--color-accent-400)] shrink-0">
            <span class="hidden sm:inline">Lire</span>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </div>
        </a>
      </div>
    </article>`;
  }

  function renderListItem(a: SearchArticle): string {
    const badge = getFreshnessBadge(a.pubDate);
    const gradient = getCatGradient(a.categories);

    const catsHtml = a.categories
      .map((c) => `<a href="/categorie/${encodeURIComponent(slugify(c))}" class="px-1.5 py-0.5 text-[0.65rem] font-medium rounded-full border ${getCatColor(c)} hover:opacity-80 transition-opacity">${escapeHtml(c)}</a>`)
      .join('');

    const imageHtml = a.image
      ? `<img src="${escapeHtml(a.image)}" alt="${escapeHtml(a.title)}" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
         <div class="w-full h-full bg-gradient-to-br ${gradient} items-center justify-center p-1 hidden"><span class="text-xs font-medium text-white/50 line-clamp-2 text-center leading-tight">${escapeHtml(a.title)}</span></div>`
      : `<div class="w-full h-full bg-gradient-to-br ${gradient} flex items-center justify-center p-1"><span class="text-xs font-medium text-white/50 line-clamp-2 text-center leading-tight">${escapeHtml(a.title)}</span></div>`;

    const badgeHtml = badge
      ? `<span class="px-1 py-0.5 rounded-full ${badge.cls}">${badge.label}</span>`
      : '';

    const typeBadgeHtml = a.type === 'podcast'
      ? `<span class="px-1 py-0.5 rounded-full border bg-fuchsia-500/20 text-fuchsia-400 border-fuchsia-500/30">${getTypeLabel(a.type as any)}</span>`
      : a.type === 'youtube'
      ? `<span class="px-1 py-0.5 rounded-full border bg-red-500/20 text-red-400 border-red-500/30">${getTypeLabel(a.type as any)}</span>`
      : '';

    const metaBadges = [badgeHtml, typeBadgeHtml].filter(Boolean).join('<span class="mx-1">•</span>');

    return `<article class="card-hover group relative rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-1)] overflow-hidden fade-in-up flex items-center gap-3 p-3" data-article-id="${escapeHtml(a.id)}">
      ${renderActionButtons(a.id, 'list')}
      <a href="/article/${escapeHtml(a.id)}" class="relative block w-16 h-16 flex-shrink-0 overflow-hidden rounded-lg">
        ${imageHtml}
        ${badge ? `<span class="absolute top-1 left-1 px-1 py-0.5 text-[0.6rem] font-medium rounded-full ${badge.cls}">${badge.label}</span>` : ''}
        ${(a.type === 'podcast' || a.type === 'youtube') ? `<span class="absolute top-1 right-1 px-1 py-0.5 text-[0.6rem] font-medium rounded-full border ${a.type === 'podcast' ? 'bg-fuchsia-500/20 text-fuchsia-400 border-fuchsia-500/30' : 'bg-red-500/20 text-red-400 border-red-500/30'}">${getTypeLabel(a.type as any)}</span>` : ''}
      </a>
      <div class="flex-1 min-w-0">
        <h3 class="font-semibold text-sm leading-snug line-clamp-1">
          <a href="/article/${escapeHtml(a.id)}" class="hover:text-[var(--color-accent-400)] transition-colors">
            ${escapeHtml(a.title)}
          </a>
        </h3>
        <div class="flex items-center gap-2 text-xs text-[var(--color-text-secondary)] mt-1 flex-wrap">
          <span>${escapeHtml(a.source)}</span>
          <span>•</span>
          <time datetime="${escapeHtml(a.pubDate)}">${formatDate(a.pubDate)}</time>
          ${metaBadges ? `<span>•</span>${metaBadges}` : ''}
        </div>
        <div class="flex flex-wrap gap-1 mt-1.5">
          ${catsHtml}
        </div>
      </div>
    </article>`;
  }

  function formatShortDate(dateStr: string): string {
    const d = new Date(dateStr);
    return `${String(d.getDate()).padStart(2, '0')}/${String(d.getMonth() + 1).padStart(2, '0')}`;
  }

  function renderCompactItem(a: SearchArticle): string {
    const primaryCategory = a.categories[0];
    const fav = isFavorited(a.id);
    const later = isReadLater(a.id);
    const favFill = fav ? '#fbbf24' : 'none';
    const laterFill = later ? '#60a5fa' : 'none';

    const typeBadgeHtml = (a.type === 'podcast' || a.type === 'youtube')
      ? `<span class="text-[10px] px-1.5 py-0.5 rounded-full border ${a.type === 'podcast' ? 'bg-fuchsia-500/20 text-fuchsia-400 border-fuchsia-500/30' : 'bg-red-500/20 text-red-400 border-red-500/30'} shrink-0">${getTypeLabel(a.type as any)}</span>`
      : '';

    const categoryHtml = primaryCategory
      ? `<a href="/categorie/${encodeURIComponent(slugify(primaryCategory))}" class="text-[10px] text-[var(--color-text-muted)] shrink-0 hidden lg:inline-block hover:text-[var(--color-accent-400)] transition-colors truncate max-w-[100px]">${escapeHtml(primaryCategory)}</a>`
      : '';

    return `<article class="card-hover group relative flex items-center gap-3 py-2 px-3 hover:bg-[var(--color-surface-2)] transition-colors" data-article-id="${escapeHtml(a.id)}">
      <time datetime="${escapeHtml(a.pubDate)}" class="text-[11px] tabular-nums text-[var(--color-text-muted)] shrink-0 w-12 hidden sm:block">${formatShortDate(a.pubDate)}</time>
      <a href="/article/${escapeHtml(a.id)}" class="text-sm font-medium flex-1 min-w-0 truncate hover:text-[var(--color-accent-400)] transition-colors">${escapeHtml(a.title)}</a>
      ${categoryHtml}
      <span class="text-xs text-[var(--color-text-secondary)] shrink-0 hidden md:inline-block truncate max-w-[140px]">${escapeHtml(a.source)}</span>
      ${typeBadgeHtml}
      <button data-favorite-toggle data-article-id="${escapeHtml(a.id)}" aria-label="Ajouter aux favoris" class="w-6 h-6 flex items-center justify-center rounded hover:bg-[var(--color-surface-overlay)] transition-colors shrink-0">
        <svg class="w-3.5 h-3.5 favorite-icon" fill="${favFill}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path class="favorite-outline" stroke-linecap="round" stroke-linejoin="round" d="${FAVORITE_PATH}" />
        </svg>
      </button>
      <button data-read-later-toggle data-article-id="${escapeHtml(a.id)}" aria-label="Lire plus tard" class="w-6 h-6 flex items-center justify-center rounded hover:bg-[var(--color-surface-overlay)] transition-colors shrink-0">
        <svg class="w-3.5 h-3.5 read-later-icon" fill="${laterFill}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="${READ_LATER_PATH}" />
        </svg>
      </button>
    </article>`;
  }

  document.addEventListener('astro:page-load', () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
    const browseMode = document.getElementById('browse-mode');
    const searchModeEl = document.getElementById('search-mode');
    const searchResults = document.getElementById('search-results');
    const searchPagination = document.getElementById('search-pagination');
    const resultsCount = document.getElementById('results-count');
    const noResults = document.getElementById('no-results');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const sourceSelect = document.getElementById('source-select') as HTMLSelectElement | null;
    const typeSelect = document.getElementById('type-select') as HTMLSelectElement | null;

    let activeCategory = 'all';
    let activeSource = 'all';
    let activeType = 'all';
    let activeFromDate: Date | null = null;
    let activeToDate: Date | null = null;
    let searchQuery = '';
    let currentSearchPage = 1;
    let currentPageSize = readPageSize();

    function isFilterActive(): boolean {
      return searchQuery.length >= 2 || activeCategory !== 'all' || activeSource !== 'all' || activeType !== 'all' || activeFromDate !== null || activeToDate !== null || currentPageSize !== DEFAULT_PAGE_SIZE;
    }

    async function updateView() {
      if (!isFilterActive()) {
        browseMode?.classList.remove('hidden');
        searchModeEl?.classList.add('hidden');
        noResults?.classList.add('hidden');
        resultsCount?.classList.add('hidden');
        return;
      }

      const index = await loadSearchIndex();
      if (!fuse) {
        fuse = new Fuse(index, {
          keys: ['title', 'description', 'source', 'categories'],
          threshold: 0.3,
          ignoreLocation: true,
        });
      }

      let results: SearchArticle[] = [...index];
      if (searchQuery.length >= 2) {
        results = fuse.search(searchQuery).map((r) => r.item);
      }
      if (activeCategory !== 'all') {
        results = results.filter((a) => a.categories.includes(activeCategory));
      }
      if (activeSource !== 'all') {
        results = results.filter((a) => a.source === activeSource);
      }
      if (activeType !== 'all') {
        results = results.filter((a) => (a.type || 'blog') === activeType);
      }
      if (activeFromDate) {
        results = results.filter((a) => new Date(a.pubDate) >= activeFromDate!);
      }
      if (activeToDate) {
        results = results.filter((a) => new Date(a.pubDate) <= activeToDate!);
      }

      browseMode?.classList.add('hidden');

      if (results.length === 0) {
        searchModeEl?.classList.add('hidden');
        noResults?.classList.remove('hidden');
        resultsCount?.classList.add('hidden');
        return;
      }

      noResults?.classList.add('hidden');
      searchModeEl?.classList.remove('hidden');
      resultsCount?.classList.remove('hidden');

      const totalPages = Math.ceil(results.length / currentPageSize);
      if (currentSearchPage > totalPages) currentSearchPage = totalPages;
      const start = (currentSearchPage - 1) * currentPageSize;
      const pageResults = results.slice(start, start + currentPageSize);

      if (resultsCount) {
        resultsCount.textContent = `${results.length} article${results.length > 1 ? 's' : ''} trouvé${results.length > 1 ? 's' : ''}`;
      }

      // Render all view containers so toggling between views is instant.
      // The CSS rule in global.css hides the containers that don't match html[data-view-mode].
      const searchResultsCards = document.getElementById('search-results');
      const searchResultsList = document.getElementById('search-results-list');
      const searchResultsCompact = document.getElementById('search-results-compact');
      if (searchResultsCards) {
        searchResultsCards.innerHTML = pageResults.map((a) => renderCard(a)).join('');
      }
      if (searchResultsList) {
        searchResultsList.innerHTML = pageResults.map((a) => renderListItem(a)).join('');
      }
      if (searchResultsCompact) {
        searchResultsCompact.innerHTML = pageResults.map((a) => renderCompactItem(a)).join('');
      }

      renderSearchPagination(totalPages);
    }

    function renderSearchPagination(totalPages: number) {
      if (!searchPagination) return;
      if (totalPages <= 1) {
        searchPagination.innerHTML = '';
        return;
      }

      const pgs: (number | string)[] = [];
      for (let i = 1; i <= totalPages; i++) {
        if (i === 1 || i === totalPages || (i >= currentSearchPage - 1 && i <= currentSearchPage + 1)) {
          pgs.push(i);
        } else if (pgs[pgs.length - 1] !== '...') {
          pgs.push('...');
        }
      }

      let html = '';
      if (currentSearchPage > 1) {
        html += `<button data-page="${currentSearchPage - 1}" class="search-page-btn px-3 py-2 text-sm rounded-lg border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)] transition-all cursor-pointer" aria-label="Page précédente">←</button>`;
      }
      for (const p of pgs) {
        if (p === '...') {
          html += `<span class="px-2 py-2 text-sm text-[var(--color-text-subtle)]">…</span>`;
        } else if (p === currentSearchPage) {
          html += `<span class="px-3 py-2 text-sm rounded-lg border font-medium accent-pagination-active" aria-current="page">${p}</span>`;
        } else {
          html += `<button data-page="${p}" class="search-page-btn px-3 py-2 text-sm rounded-lg border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)] transition-all cursor-pointer">${p}</button>`;
        }
      }
      if (currentSearchPage < totalPages) {
        html += `<button data-page="${currentSearchPage + 1}" class="search-page-btn px-3 py-2 text-sm rounded-lg border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)] transition-all cursor-pointer" aria-label="Page suivante">→</button>`;
      }

      searchPagination.innerHTML = html;
      searchPagination.querySelectorAll('.search-page-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          currentSearchPage = parseInt((btn as HTMLElement).dataset.page || '1');
          updateView();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });
    }

    // Search input with debounce
    let debounceTimer: ReturnType<typeof setTimeout>;
    searchInput?.addEventListener('input', (e) => {
      searchQuery = (e.target as HTMLInputElement).value;
      currentSearchPage = 1;
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => updateView(), 200);
    });

    // Keyboard shortcut
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== searchInput) {
        e.preventDefault();
        searchInput?.focus();
      }
    });

    // Category filter
    const activeClasses = ['accent-filter-active'];
    const inactiveClasses = ['filter-btn-inactive'];

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeCategory = (btn as HTMLElement).dataset.category || 'all';
        filterBtns.forEach((b) => {
          b.classList.remove('active', ...activeClasses);
          b.classList.add(...inactiveClasses);
        });
        btn.classList.add('active', ...activeClasses);
        btn.classList.remove(...inactiveClasses);
        currentSearchPage = 1;
        updateView();
      });
    });

    // Source filter
    sourceSelect?.addEventListener('change', () => {
      activeSource = sourceSelect.value;
      currentSearchPage = 1;
      updateView();
    });

    // Type filter
    typeSelect?.addEventListener('change', () => {
      activeType = typeSelect.value;
      currentSearchPage = 1;
      updateView();
    });

    // Page size selector
    const pageSizeSelect = document.getElementById('page-size-select') as HTMLSelectElement | null;
    if (pageSizeSelect) {
      pageSizeSelect.value = String(currentPageSize);
      pageSizeSelect.addEventListener('change', () => {
        const n = parseInt(pageSizeSelect.value, 10);
        currentPageSize = PAGE_SIZE_OPTIONS.includes(n) ? n : DEFAULT_PAGE_SIZE;
        try { localStorage.setItem(PAGE_SIZE_KEY, String(currentPageSize)); } catch {}
        currentSearchPage = 1;
        updateView();
      });
    }

    // If a non-default page size was restored from localStorage, switch to client-side rendering on load
    if (currentPageSize !== DEFAULT_PAGE_SIZE) {
      updateView();
    }

    // Date filters
    const dateFromInput = document.getElementById('date-from') as HTMLInputElement | null;
    const dateToInput = document.getElementById('date-to') as HTMLInputElement | null;
    const preset7dBtn = document.getElementById('preset-7d');
    const preset30dBtn = document.getElementById('preset-30d');
    const presetMonthBtn = document.getElementById('preset-month');
    const resetDatesBtn = document.getElementById('reset-dates');

    function parseDateInput(value: string, endOfDay: boolean): Date | null {
      if (!value) return null;
      const d = new Date(value + (endOfDay ? 'T23:59:59.999' : 'T00:00:00'));
      return isNaN(d.getTime()) ? null : d;
    }

    function applyDateChange() {
      activeFromDate = parseDateInput(dateFromInput?.value || '', false);
      activeToDate = parseDateInput(dateToInput?.value || '', true);
      currentSearchPage = 1;
      updateView();
    }

    dateFromInput?.addEventListener('change', applyDateChange);
    dateToInput?.addEventListener('change', applyDateChange);

    function setDateRange(fromDaysAgo: number, to: Date = new Date()) {
      const from = new Date(to);
      from.setDate(from.getDate() - fromDaysAgo);
      const toIso = to.toISOString().slice(0, 10);
      const fromIso = from.toISOString().slice(0, 10);
      if (dateFromInput) dateFromInput.value = fromIso;
      if (dateToInput) dateToInput.value = toIso;
      applyDateChange();
    }

    preset7dBtn?.addEventListener('click', () => setDateRange(7));
    preset30dBtn?.addEventListener('click', () => setDateRange(30));
    presetMonthBtn?.addEventListener('click', () => {
      const now = new Date();
      const firstOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);
      if (dateFromInput) dateFromInput.value = firstOfMonth.toISOString().slice(0, 10);
      if (dateToInput) dateToInput.value = now.toISOString().slice(0, 10);
      applyDateChange();
    });
    resetDatesBtn?.addEventListener('click', () => {
      if (dateFromInput) dateFromInput.value = '';
      if (dateToInput) dateToInput.value = '';
      applyDateChange();
    });


    // Mark new articles (localStorage) - static cards only
    const LAST_VISIT_KEY = 'flux-last-visit';
    const lastVisit = localStorage.getItem(LAST_VISIT_KEY);
    if (lastVisit && browseMode) {
      const cards = Array.from(browseMode.querySelectorAll('article'));
      cards.forEach((card) => {
        const id = card.getAttribute('data-article-id');
        if (id && !localStorage.getItem(`flux-read-${id}`)) {
          const titleEl = card.querySelector('h3');
          if (titleEl) {
            const dot = document.createElement('span');
            dot.className = 'w-2 h-2 rounded-full accent-dot inline-block ml-1.5 flex-shrink-0';
            dot.title = 'Non lu';
            titleEl.classList.add('flex', 'items-start');
            titleEl.appendChild(dot);
          }
        }
      });
    }
    localStorage.setItem(LAST_VISIT_KEY, new Date().toISOString());
  });
</script>
