---
import type { Article } from '../types/index';
import { getFreshnessBadge, formatDate, getCategoryGradient, getCategoryColor, getTypeLabel, getTypeColor, slugify } from '../utils/articles';

interface Props {
  article: Article;
  eager?: boolean;
}

const { article, eager = false } = Astro.props;
const badge = getFreshnessBadge(article.pubDate);
---

<article
  class="card-hover group rounded-xl border border-zinc-800 bg-[var(--color-surface-1)] overflow-hidden fade-in-up flex items-center gap-3 p-3"
  data-article-id={article.id}
  data-source={article.source}
  data-categories={article.categories.join(',')}
  data-title={article.title}
  data-description={article.description}
>
  <!-- Image -->
  <a href={`/article/${article.id}`} class="block w-16 h-16 flex-shrink-0 overflow-hidden rounded-lg">
    {article.image ? (
      <img
        src={article.image}
        alt={article.title}
        loading={eager ? "eager" : "lazy"}
        decoding={eager ? "sync" : "async"}
        fetchpriority={eager ? "high" : undefined}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
      />
      <div class={`w-full h-full bg-gradient-to-br ${getCategoryGradient(article.categories)} items-center justify-center p-1 hidden`}>
        <span class="text-xs font-medium text-white/50 line-clamp-2 text-center leading-tight">{article.title}</span>
      </div>
    ) : (
      <div class={`w-full h-full bg-gradient-to-br ${getCategoryGradient(article.categories)} flex items-center justify-center p-1`}>
        <span class="text-xs font-medium text-white/50 line-clamp-2 text-center leading-tight">{article.title}</span>
      </div>
    )}
    {badge && (
      <span class={`absolute top-1 left-1 px-1 py-0.5 text-[0.6rem] font-medium rounded-full ${badge.class}`}>
        {badge.label}
      </span>
    )}
    {(article.type === 'podcast' || article.type === 'youtube') && (
      <span class={`absolute top-1 right-1 px-1 py-0.5 text-[0.6rem] font-medium rounded-full border ${getTypeColor(article.type)}`}>
        {getTypeLabel(article.type)}
      </span>
    )}
  </a>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <!-- Title -->
    <h3 class="font-semibold text-sm leading-snug line-clamp-1">
      <a href={`/article/${article.id}`} class="hover:text-[var(--color-accent-400)] transition-colors">
        {article.title}
      </a>
    </h3>

    <!-- Meta -->
    <div class="flex items-center gap-2 text-xs text-zinc-400 mt-1 flex-wrap">
      <span>{article.source}</span>
      <span>•</span>
      <time datetime={article.pubDate}>{formatDate(article.pubDate)}</time>
      {badge && (
        <>
          <span>•</span>
          <span class={`px-1 py-0.5 rounded-full ${badge.class}`}>{badge.label}</span>
        </>
      )}
      {(article.type === 'podcast' || article.type === 'youtube') && (
        <>
          <span>•</span>
          <span class={`px-1 py-0.5 rounded-full border ${getTypeColor(article.type)}`}>{getTypeLabel(article.type)}</span>
        </>
      )}
    </div>

    <!-- Categories -->
    <div class="flex flex-wrap gap-1 mt-1.5">
      {article.categories.map((cat) => (
        <a href={`/categorie/${slugify(cat)}`} class={`px-1.5 py-0.5 text-[0.65rem] font-medium rounded-full border ${getCategoryColor(cat)} hover:opacity-80 transition-opacity`}>
          {cat}
        </a>
      ))}
    </div>
    
          <!-- Favorite button -->
          <button 
            data-favorite-toggle 
            data-article-id={article.id}
            aria-label="Ajouter aux favoris"
            class="absolute top-1 right-8 w-6 h-6 flex items-center justify-center rounded-lg bg-zinc-900/50 hover:bg-zinc-800 transition-colors"
          >
            <svg class="w-3 h-3 favorite-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path class="favorite-outline" stroke-linecap="round" stroke-linejoin="round" d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.75.75 0 01-.712 0l-.003-.001z" />
            </svg>
          </button>
          
          <!-- Read later button -->
          <button 
            data-read-later-toggle 
            data-article-id={article.id}
            aria-label="Lire plus tard"
            class="absolute top-1 right-14 w-6 h-6 flex items-center justify-center rounded-lg bg-zinc-900/50 hover:bg-zinc-800 transition-colors"
          >
            <svg class="w-3 h-3 read-later-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
            </svg>
          </button>
  </div>
</article>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    // Update favorite button state on page load
    const favoriteButtons = document.querySelectorAll('[data-favorite-toggle][data-article-id]');
    favoriteButtons.forEach(button => {
      const articleId = button.getAttribute('data-article-id');
      if (articleId) {
        try {
          const favorites = JSON.parse(localStorage.getItem('flux-favorites') || '[]');
          const isFavorite = favorites.includes(articleId);
          const icon = button.querySelector('.favorite-icon');
          const outlinePath = button.querySelector('.favorite-outline');
          
          if (isFavorite && icon) {
            icon.setAttribute('fill', '#fbbf24'); // yellow fill for favorited state
            if (outlinePath) {
              outlinePath.setAttribute('d', 'M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.75.75 0 01-.712 0l-.003-.001z');
            }
          }
        } catch (e) {
          // Ignore localStorage errors
        }
      }
    });
  });
</script>