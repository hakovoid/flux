---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/Header.astro';
import BackToTop from '../components/BackToTop.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalOverride?: string;
  noindex?: boolean;
}

const { title, description = 'Agrégateur de veille technologique — Les derniers articles tech, IA, DevOps, Cloud et Cybersécurité.', image, canonicalOverride, noindex = false } = Astro.props;
const canonicalURL = canonicalOverride || new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = image || 'https://flux.yoandev.co/og.webp';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | Flux YoanDev</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="fr" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`Flux YoanDev | ${title}`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Flux — Veille technologique" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`Flux YoanDev | ${title}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Flux RSS" href="/rss.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" /></noscript>

    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="f5c6dbb9-2354-4f04-9810-6ef063f229a7"></script>

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Flux — Veille technologique",
      "url": "https://flux.yoandev.co",
      "description": "Agrégateur de veille technologique francophone — Articles, podcasts et vidéos sur la programmation, l'IA, le DevOps, le Cloud et la cybersécurité.",
      "inLanguage": "fr",
      "publisher": {
        "@type": "Person",
        "name": "YoanDev",
        "url": "https://yoandev.co"
      }
    })} />
    <slot name="head" />

    <ClientRouter fallback="swap" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>
    <footer class="border-t border-zinc-800/60 py-8 text-sm text-zinc-500">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-6">
          <div>
            <h4 class="text-xs uppercase tracking-widest text-zinc-600 font-medium mb-3">Catégories</h4>
            <nav class="flex flex-col gap-1.5">
              <a href="/categorie/programmation" class="text-zinc-500 hover:text-indigo-400 transition-colors">Programmation</a>
              <a href="/categorie/ia" class="text-zinc-500 hover:text-indigo-400 transition-colors">IA</a>
              <a href="/categorie/devops" class="text-zinc-500 hover:text-indigo-400 transition-colors">DevOps</a>
              <a href="/categorie/cloud" class="text-zinc-500 hover:text-indigo-400 transition-colors">Cloud</a>
              <a href="/categorie/web" class="text-zinc-500 hover:text-indigo-400 transition-colors">Web</a>
              <a href="/categorie/cybersecurite" class="text-zinc-500 hover:text-indigo-400 transition-colors">Cybersécurité</a>
            </nav>
          </div>
          <div>
            <h4 class="text-xs uppercase tracking-widest text-zinc-600 font-medium mb-3">Navigation</h4>
            <nav class="flex flex-col gap-1.5">
              <a href="/" class="text-zinc-500 hover:text-indigo-400 transition-colors">Articles</a>
              <a href="/sources" class="text-zinc-500 hover:text-indigo-400 transition-colors">Sources</a>
              <a href="/categories" class="text-zinc-500 hover:text-indigo-400 transition-colors">Catégories</a>
              <a href="/stats" class="text-zinc-500 hover:text-indigo-400 transition-colors">Statistiques</a>
              <a href="/newsletter" class="text-zinc-500 hover:text-indigo-400 transition-colors">Newsletter</a>
              <a href="/a-propos" class="text-zinc-500 hover:text-indigo-400 transition-colors">À propos</a>
            </nav>
          </div>
          <div>
            <h4 class="text-xs uppercase tracking-widest text-zinc-600 font-medium mb-3">Flux</h4>
            <nav class="flex flex-col gap-1.5">
              <a href="/rss.xml" class="text-zinc-500 hover:text-indigo-400 transition-colors inline-flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
                Flux RSS
              </a>
              <a href="/world/rss.xml" class="text-zinc-500 hover:text-indigo-400 transition-colors inline-flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
                Flux RSS World
              </a>
              <a href="https://github.com/yoanbernabeu/flux" target="_blank" rel="noopener noreferrer" class="text-zinc-500 hover:text-indigo-400 transition-colors">Code source</a>
              <a href="https://www.patreon.com/YoanDev" target="_blank" rel="noopener noreferrer" class="text-zinc-500 hover:text-amber-400 transition-colors inline-flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M14.82 2.41c3.96 0 7.18 3.24 7.18 7.21 0 3.96-3.22 7.18-7.18 7.18-3.97 0-7.21-3.22-7.21-7.18 0-3.97 3.24-7.21 7.21-7.21M2 21.6h3.5V2.41H2V21.6z"/></svg>
                Patreon
              </a>
            </nav>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-6 border-t border-zinc-800/40">
          <p>Flux — Veille technologique agrégée par <a href="https://yoandev.co" class="text-indigo-400 hover:text-indigo-300 underline transition-colors">YoanDev</a></p>
          <span class="text-zinc-600">Analytique sans cookies via <a href="https://umami.is" class="underline hover:text-indigo-400 transition-colors">Umami</a></span>
        </div>
      </div>
    </footer>
    <BackToTop />
    
    <!-- Global event delegation for favorite and read later toggles -->
    <script>
      document.addEventListener('click', (e) => {
        // Handle favorite toggle
        if (e.target.closest('[data-favorite-toggle]')) {
          const button = e.target.closest('[data-favorite-toggle]');
          const articleId = button.getAttribute('data-article-id');
          
          if (articleId) {
            try {
              // Import the userLists module dynamically
              // Since we can't import ES modules in inline scripts, we'll reimplement the logic
              const STORAGE_PREFIX = 'flux-';
              
              // Get list from localStorage
              function getList(key) {
                try {
                  const stored = localStorage.getItem(STORAGE_PREFIX + key);
                  return stored ? JSON.parse(stored) : [];
                } catch (e) {
                  return [];
                }
              }
              
              // Set list to localStorage
              function setList(key, items) {
                try {
                  localStorage.setItem(STORAGE_PREFIX + key, JSON.stringify(items));
                } catch (e) {
                  // Silently fail if localStorage is unavailable
                }
              }
              
              // Toggle item in list
              function toggle(key, id) {
                if (key === 'read-later') {
                  // Handle read-later with timestamps
                  const list = getList(key);
                  const index = list.findIndex(item => item.id === id);
                  if (index === -1) {
                    // Add new item with timestamp
                    list.push({ id, addedAt: Date.now() });
                    setList(key, list);
                    return true;
                  } else {
                    // Remove existing item
                    list.splice(index, 1);
                    setList(key, list);
                    return false;
                  }
                } else {
                  // Handle favorites (simple string array)
                  const list = getList(key);
                  const index = list.indexOf(id);
                  if (index === -1) {
                    list.push(id);
                    setList(key, list);
                    return true;
                  } else {
                    list.splice(index, 1);
                    setList(key, list);
                    return false;
                  }
                }
              }
              
              // Toggle favorite
              const isNowFavorite = toggle('favorites', articleId);
              
              // Update button appearance
              const icon = button.querySelector('.favorite-icon');
              if (icon) {
                if (isNowFavorite) {
                  icon.setAttribute('fill', '#fbbf24'); // Yellow fill for favorited state
                  const outlinePath = icon.querySelector('path');
                  if (outlinePath) {
                    outlinePath.setAttribute('d', 'M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.185 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.75.75 0 01-.712 0l-.003-.001z');
                  }
                } else {
                  icon.setAttribute('fill', 'none'); // No fill for unfavorited state
                  const outlinePath = icon.querySelector('path');
                  if (outlinePath) {
                    outlinePath.setAttribute('d', 'M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.75.75 0 01-.712 0l-.003-.001z');
                  }
                }
              }
              
              // Update header counters
              try {
                // Update favorites counter
                const favorites = getList('favorites');
                const favoritesCounterElements = document.querySelectorAll('[data-favorites-count]');
                favoritesCounterElements.forEach(el => {
                  el.textContent = favorites.length.toString();
                  el.style.display = favorites.length > 0 ? 'inline-flex' : 'none';
                });
                
                // Update read later counter
                const readLaterItems = getList('read-later');
                const readLaterCounterElements = document.querySelectorAll('[data-read-later-count]');
                readLaterCounterElements.forEach(el => {
                  el.textContent = Array.isArray(readLaterItems) ? readLaterItems.length.toString() : '0';
                  el.style.display = Array.isArray(readLaterItems) && readLaterItems.length > 0 ? 'inline-flex' : 'none';
                });
              } catch (e) {
                // Ignore localStorage errors
              }
              
              // If we're on the favorites page, update the list
              if (window.location.pathname === '/favoris') {
                // This would require more complex logic to update the favorites page
                // For now, we'll let the page refresh handle it
              }
            } catch (err) {
              console.error('Error toggling favorite:', err);
            }
          }
        }
        
        // Handle read later toggle
        if (e.target.closest('[data-read-later-toggle]')) {
          const button = e.target.closest('[data-read-later-toggle]');
          const articleId = button.getAttribute('data-article-id');
          
          if (articleId) {
            try {
              // Import the userLists module dynamically
              // Since we can't import ES modules in inline scripts, we'll reimplement the logic
              const STORAGE_PREFIX = 'flux-';
              
              // Get list from localStorage
              function getList(key) {
                try {
                  const stored = localStorage.getItem(STORAGE_PREFIX + key);
                  return stored ? JSON.parse(stored) : [];
                } catch (e) {
                  return [];
                }
              }
              
              // Set list to localStorage
              function setList(key, items) {
                try {
                  localStorage.setItem(STORAGE_PREFIX + key, JSON.stringify(items));
                } catch (e) {
                  // Silently fail if localStorage is unavailable
                }
              }
              
              // Toggle item in list (read-later with timestamps)
              function toggleReadLater(id) {
                const list = getList('read-later');
                const index = list.findIndex(item => item.id === id);
                if (index === -1) {
                  // Add new item with timestamp
                  list.push({ id, addedAt: Date.now() });
                  setList('read-later', list);
                  return true;
                } else {
                  // Remove existing item
                  list.splice(index, 1);
                  setList('read-later', list);
                  return false;
                }
              }
              
              // Toggle read later
              const isNowReadLater = toggleReadLater(articleId);
              
              // Update button appearance
              const icon = button.querySelector('.read-later-icon');
              if (icon) {
                if (isNowReadLater) {
                  icon.setAttribute('fill', '#60a5fa'); // Blue fill for read later state
                } else {
                  icon.setAttribute('fill', 'none'); // No fill for removed state
                }
              }
              
              // Update header counters
              try {
                // Update read later counter
                const readLaterItems = getList('read-later');
                const readLaterCounterElements = document.querySelectorAll('[data-read-later-count]');
                readLaterCounterElements.forEach(el => {
                  el.textContent = Array.isArray(readLaterItems) ? readLaterItems.length.toString() : '0';
                  el.style.display = Array.isArray(readLaterItems) && readLaterItems.length > 0 ? 'inline-flex' : 'none';
                });
                
                // Update favorites counter (in case both are toggled)
                const favorites = getList('favorites');
                const favoritesCounterElements = document.querySelectorAll('[data-favorites-count]');
                favoritesCounterElements.forEach(el => {
                  el.textContent = favorites.length.toString();
                  el.style.display = favorites.length > 0 ? 'inline-flex' : 'none';
                });
              } catch (e) {
                // Ignore localStorage errors
              }
              
              // If we're on the read later page, update the list
              if (window.location.pathname === '/a-lire-plus-tard') {
                // This would require more complex logic to update the read later page
                // For now, we'll let the page refresh handle it
              }
            } catch (err) {
              console.error('Error toggling read later:', err);
            }
          }
        }
        
        // Handle mark as read on read later page
        if (e.target.closest('[data-mark-as-read]')) {
          const button = e.target.closest('[data-mark-as-read]');
          const articleId = button.getAttribute('data-article-id');
          
          if (articleId) {
            try {
              // Import the userLists module dynamically
              // Since we can't import ES modules in inline scripts, we'll reimplement the logic
              const STORAGE_PREFIX = 'flux-';
              
              // Remove from read-later list
              function removeFromReadLater(id) {
                try {
                  const stored = localStorage.getItem(STORAGE_PREFIX + 'read-later');
                  const list = stored ? JSON.parse(stored) : [];
                  if (Array.isArray(list)) {
                    const filtered = list.filter(item => item.id !== id);
                    localStorage.setItem(STORAGE_PREFIX + 'read-later', JSON.stringify(filtered));
                  }
                } catch (e) {
                  // Ignore errors
                }
              }
              
              // Remove from read-later list
              removeFromReadLater(articleId);
              
              // Remove the article element from the DOM
              const articleElement = button.closest('article');
              if (articleElement) {
                articleElement.remove();
                
                // Check if no items left
                const container = document.getElementById('read-later-container');
                if (container && container.children.length === 0) {
                  document.getElementById('read-later-empty').classList.remove('hidden');
                }
                
                // Update header counter
                try {
                  const stored = localStorage.getItem(STORAGE_PREFIX + 'read-later');
                  const list = stored ? JSON.parse(stored) : [];
                  const counterElements = document.querySelectorAll('[data-read-later-count]');
                  const count = Array.isArray(list) ? list.length : 0;
                  counterElements.forEach(el => {
                    el.textContent = count.toString();
                    el.style.display = count > 0 ? 'inline-flex' : 'none';
                  });
                } catch (e) {
                  // Ignore localStorage errors
                }
              }
            } catch (err) {
              console.error('Error marking as read:', err);
            }
          }
        }
      });
    </script>
  </body>
</html>
