---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SearchBar from '../components/SearchBar.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import { loadAllArticles, getAllCategories, getAllSources } from '../utils/articles';

const allArticles = loadAllArticles();
const categories = getAllCategories(allArticles);
const sources = getAllSources(allArticles);
---

<Layout title="Veille technologique" image="https://flux.yoandev.co/og.webp">
  <div class="flex flex-col gap-6">
    <!-- Search + Filters -->
    <div class="flex flex-col gap-3 sm:gap-5 p-3 sm:p-5 rounded-2xl bg-[var(--color-surface-1)]/50 border border-zinc-800/50 backdrop-blur-sm">
      <div class="flex items-center gap-2">
        <div class="flex-1">
          <SearchBar />
        </div>
        <button
          id="toggle-filters"
          aria-label="Afficher les filtres"
          aria-expanded="false"
          class="sm:hidden flex items-center justify-center w-11 h-11 rounded-2xl border border-zinc-800 bg-[var(--color-surface-1)] text-zinc-400 hover:text-white hover:border-zinc-600 transition-all cursor-pointer shrink-0"
        >
          <svg id="filter-icon-closed" class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" />
          </svg>
          <svg id="filter-icon-open" class="w-[18px] h-[18px] hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div id="filters-panel" class="hidden sm:block overflow-hidden transition-all duration-300">
        <CategoryFilter categories={categories} sources={sources} />
      </div>
    </div>

    <script is:inline>
      (function() {
        var btn = document.getElementById('toggle-filters');
        var panel = document.getElementById('filters-panel');
        var iconClosed = document.getElementById('filter-icon-closed');
        var iconOpen = document.getElementById('filter-icon-open');
        if (btn && panel) {
          btn.onclick = function() {
            var isOpen = !panel.classList.contains('hidden');
            if (isOpen) {
              panel.classList.add('hidden');
              if (iconClosed) iconClosed.classList.remove('hidden');
              if (iconOpen) iconOpen.classList.add('hidden');
              btn.setAttribute('aria-expanded', 'false');
            } else {
              panel.classList.remove('hidden');
              if (iconClosed) iconClosed.classList.add('hidden');
              if (iconOpen) iconOpen.classList.remove('hidden');
              btn.setAttribute('aria-expanded', 'true');
            }
          };
        }
      })();
    </script>

    <!-- Results count -->
    <div id="results-count" class="text-xs text-zinc-500"></div>

    <!-- Articles Grid -->
    <div id="articles-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {allArticles.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>

    <!-- Empty State -->
    {allArticles.length === 0 && (
      <div class="text-center py-20 text-zinc-500">
        <svg class="w-12 h-12 mx-auto mb-4 text-zinc-700" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" />
        </svg>
        <p class="text-lg font-medium">Aucun article pour le moment</p>
        <p class="text-sm mt-1">Les articles apparaîtront après la première synchronisation RSS.</p>
      </div>
    )}

    <!-- No search results (hidden by default) -->
    <div id="no-results" class="hidden text-center py-20 text-zinc-500">
      <p class="text-lg font-medium">Aucun résultat</p>
      <p class="text-sm mt-1">Essayez avec d'autres termes de recherche.</p>
    </div>

    <!-- Client-side pagination -->
    <nav id="pagination" aria-label="Pagination" class="flex items-center justify-center gap-1.5 mt-4"></nav>
  </div>
</Layout>

<script>
  import Fuse from 'fuse.js';

  const PAGE_SIZE = 15;

  interface ArticleData {
    id: string;
    title: string;
    description: string;
    source: string;
    categories: string[];
    element: HTMLElement;
  }

  document.addEventListener('astro:page-load', () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const grid = document.getElementById('articles-grid');
    const noResults = document.getElementById('no-results');
    const paginationNav = document.getElementById('pagination');
    const resultsCount = document.getElementById('results-count');
    const cards = grid ? Array.from(grid.querySelectorAll('article')) : [];
    const filterBtns = document.querySelectorAll('.filter-btn');
    const sourceSelect = document.getElementById('source-select') as HTMLSelectElement;

    // Build article data from DOM data attributes
    const allArticles: ArticleData[] = cards.map((card) => ({
      id: card.getAttribute('data-article-id') || '',
      title: card.getAttribute('data-title') || '',
      description: card.getAttribute('data-description') || '',
      source: card.getAttribute('data-source') || '',
      categories: (card.getAttribute('data-categories') || '').split(',').filter(Boolean),
      element: card as HTMLElement,
    }));

    // Fuse.js
    const fuse = new Fuse(allArticles, {
      keys: ['title', 'description', 'source', 'categories'],
      threshold: 0.3,
      ignoreLocation: true,
    });

    let activeCategory = 'all';
    let activeSource = 'all';
    let searchQuery = '';
    let currentPage = 1;

    function getFilteredArticles(): ArticleData[] {
      let results = allArticles;

      // Search
      if (searchQuery.length >= 2) {
        results = fuse.search(searchQuery).map((r) => r.item);
      }

      // Category
      if (activeCategory !== 'all') {
        results = results.filter((a) => a.categories.includes(activeCategory));
      }

      // Source
      if (activeSource !== 'all') {
        results = results.filter((a) => a.source === activeSource);
      }

      return results;
    }

    function renderPage() {
      const filtered = getFilteredArticles();
      const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
      if (currentPage > totalPages) currentPage = totalPages;

      const start = (currentPage - 1) * PAGE_SIZE;
      const pageItems = new Set(filtered.slice(start, start + PAGE_SIZE).map((a) => a.id));

      // Show/hide cards
      allArticles.forEach((a) => {
        a.element.style.display = pageItems.has(a.id) ? '' : 'none';
      });

      // Results count
      if (resultsCount) {
        if (searchQuery.length >= 2 || activeCategory !== 'all' || activeSource !== 'all') {
          resultsCount.textContent = `${filtered.length} article${filtered.length > 1 ? 's' : ''} trouvé${filtered.length > 1 ? 's' : ''}`;
        } else {
          resultsCount.textContent = '';
        }
      }

      // No results
      if (noResults) {
        noResults.classList.toggle('hidden', filtered.length > 0 || allArticles.length === 0);
      }

      // Pagination
      renderPagination(totalPages);
    }

    function renderPagination(totalPages: number) {
      if (!paginationNav) return;
      if (totalPages <= 1) {
        paginationNav.innerHTML = '';
        return;
      }

      const pages: (number | '...')[] = [];
      for (let i = 1; i <= totalPages; i++) {
        if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
          pages.push(i);
        } else if (pages[pages.length - 1] !== '...') {
          pages.push('...');
        }
      }

      let html = '';

      if (currentPage > 1) {
        html += `<button data-page="${currentPage - 1}" class="page-btn px-3 py-2 text-sm rounded-lg border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-600 transition-all cursor-pointer" aria-label="Page précédente">←</button>`;
      }

      for (const p of pages) {
        if (p === '...') {
          html += `<span class="px-2 py-2 text-sm text-zinc-600">…</span>`;
        } else if (p === currentPage) {
          html += `<span class="px-3 py-2 text-sm rounded-lg bg-indigo-500/20 border border-indigo-500/50 text-indigo-400 font-medium" aria-current="page">${p}</span>`;
        } else {
          html += `<button data-page="${p}" class="page-btn px-3 py-2 text-sm rounded-lg border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-600 transition-all cursor-pointer">${p}</button>`;
        }
      }

      if (currentPage < totalPages) {
        html += `<button data-page="${currentPage + 1}" class="page-btn px-3 py-2 text-sm rounded-lg border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-600 transition-all cursor-pointer" aria-label="Page suivante">→</button>`;
      }

      paginationNav.innerHTML = html;

      // Bind page buttons
      paginationNav.querySelectorAll('.page-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          currentPage = parseInt((btn as HTMLElement).dataset.page || '1');
          renderPage();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });
    }

    // Search
    searchInput?.addEventListener('input', (e) => {
      searchQuery = (e.target as HTMLInputElement).value;
      currentPage = 1;
      renderPage();
    });

    // Keyboard shortcut
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== searchInput) {
        e.preventDefault();
        searchInput?.focus();
      }
    });

    // Category filter
    const activeClasses = ['bg-indigo-500/15', 'text-indigo-300', 'border-indigo-500/40', 'shadow-[0_0_12px_-3px]', 'shadow-indigo-500/20'];
    const inactiveClasses = ['bg-zinc-800/50', 'text-zinc-400', 'border-zinc-700/50'];

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeCategory = (btn as HTMLElement).dataset.category || 'all';
        filterBtns.forEach((b) => {
          b.classList.remove('active', ...activeClasses);
          b.classList.add(...inactiveClasses);
        });
        btn.classList.add('active', ...activeClasses);
        btn.classList.remove(...inactiveClasses);
        currentPage = 1;
        renderPage();
      });
    });

    // Source filter
    sourceSelect?.addEventListener('change', () => {
      activeSource = sourceSelect.value;
      currentPage = 1;
      renderPage();
    });

    // Mark new articles (localStorage)
    const LAST_VISIT_KEY = 'flux-last-visit';
    const lastVisit = localStorage.getItem(LAST_VISIT_KEY);
    if (lastVisit) {
      allArticles.forEach(({ element, id }) => {
        const readKey = `flux-read-${id}`;
        if (!localStorage.getItem(readKey)) {
          const titleEl = element.querySelector('h3');
          if (titleEl) {
            const dot = document.createElement('span');
            dot.className = 'w-2 h-2 rounded-full bg-indigo-500 inline-block ml-1.5 flex-shrink-0';
            dot.title = 'Non lu';
            titleEl.classList.add('flex', 'items-start');
            titleEl.appendChild(dot);
          }
        }
      });
    }
    localStorage.setItem(LAST_VISIT_KEY, new Date().toISOString());

    // Initial render
    renderPage();
  });
</script>
