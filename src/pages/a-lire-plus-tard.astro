---
import Layout from '../layouts/Layout.astro';
import ArticleListItem from '../components/ArticleListItem.astro';
import { loadAllArticles, loadWorldArticles } from '../utils/articles';
import { getReadLaterSorted, removeFromReadLater } from '../utils/userLists';

// Load all articles at build time
const allArticles = [...loadAllArticles(), ...loadWorldArticles()];

// Sort by date, newest first
allArticles.sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());
---

<Layout title="À lire plus tard" description="Vos articles à lire plus tard." noindex>
  <div class="fade-in-up">
    <div class="mb-8">
      <h1 class="text-2xl sm:text-3xl font-bold mb-2">À lire plus tard</h1>
      <p class="text-zinc-400 text-sm">
        Articles mis de côté pour plus tard. Ces articles sont stockés localement dans votre navigateur.
      </p>
    </div>

    <!-- Read later list container -->
    <div id="read-later-container" class="flex flex-col gap-3">
      <!-- Will be populated by client-side JavaScript -->
      <div id="read-later-placeholder" class="text-center py-20 text-zinc-500">
        <p class="text-lg font-medium">Chargement des articles...</p>
      </div>
    </div>

    <!-- Empty state -->
    <div id="read-later-empty" class="hidden text-center py-20 text-zinc-500">
      <svg class="w-12 h-12 mx-auto mb-4 text-zinc-700" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
      </svg>
      <p class="text-lg font-medium">Aucun article à lire plus tard</p>
      <p class="text-sm mt-1">Cliquez 🔖 sur un article pour l'ajouter ici.</p>
    </div>
  </div>

  <!-- Preloaded articles index for client-side filtering -->
  <script type="application/json" id="articles-index">
    {JSON.stringify(allArticles)}
  </script>

  <script>
    document.addEventListener('astro:page-load', () => {
      try {
        // Get read later items sorted by addedAt (newest first)
        const readLaterItems = getReadLaterSorted();
        
        // Get articles index
        const articlesIndexScript = document.getElementById('articles-index');
        const allArticles = JSON.parse(articlesIndexScript.textContent || '[]');
        
        // Get DOM elements
        const container = document.getElementById('read-later-container');
        const placeholder = document.getElementById('read-later-placeholder');
        const emptyState = document.getElementById('read-later-empty');
        
        // Hide placeholder
        placeholder.style.display = 'none';
        
        // Show empty state or articles
        if (readLaterItems.length === 0) {
          emptyState.classList.remove('hidden');
          return;
        }
        
        // Clear container and add articles
        container.innerHTML = '';
        readLaterItems.forEach((item, index) => {
          // Find the article in the index
          const article = allArticles.find(a => a.id === item.id);
          if (article) {
            // Create article element
            const articleEl = document.createElement('div');
            articleEl.innerHTML = renderArticleListItem(article, item.addedAt, index === 0);
            container.appendChild(articleEl.firstElementChild);
          }
        });
        
        // Add event listener for "Marquer lu" buttons
        setupMarkAsReadListener();
      } catch (e) {
        console.error('Error loading read later items:', e);
        document.getElementById('read-later-placeholder').innerHTML = '<p class="text-lg font-medium">Erreur lors du chargement des articles</p>';
      }
    });
    
    function getReadLaterSorted() {
      try {
        const stored = localStorage.getItem('flux-read-later');
        const list = stored ? JSON.parse(stored) : [];
        // Sort by addedAt descending (newest first)
        return Array.isArray(list) ? list.sort((a, b) => b.addedAt - a.addedAt) : [];
      } catch (e) {
        return [];
      }
    }
    
    function removeFromReadLater(id) {
      try {
        const stored = localStorage.getItem('flux-read-later');
        const list = stored ? JSON.parse(stored) : [];
        if (Array.isArray(list)) {
          const filtered = list.filter(item => item.id !== id);
          localStorage.setItem('flux-read-later', JSON.stringify(filtered));
        }
      } catch (e) {
        // Ignore errors
      }
    }
    
    function renderArticleListItem(article, addedAt, eager = false) {
      // Format the added date
      const addedDate = new Date(addedAt);
      const formattedAddedDate = addedDate.toLocaleDateString('fr-FR', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      });
      
      // Check if article is in read-later list
      const readLaterItems = getReadLaterSorted();
      const isReadLater = readLaterItems.some(item => item.id === article.id);
      
      return `
        <article
          class="card-hover group rounded-xl border border-zinc-800 bg-[var(--color-surface-1)] overflow-hidden fade-in-up flex items-center gap-3 p-3 relative"
          data-article-id="${article.id}"
        >
          <a href="/article/${article.id}" class="block w-16 h-16 flex-shrink-0 overflow-hidden rounded-lg">
            ${
              article.image
                ? `<img
                    src="${article.image}"
                    alt="${article.title}"
                    loading="${eager ? 'eager' : 'lazy'}"
                    decoding="${eager ? 'sync' : 'async'}"
                    fetchpriority="${eager ? 'high' : ''}"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                  />
                  <div class="w-full h-full bg-gradient-to-br from-zinc-600 to-zinc-800 items-center justify-center p-1 hidden">
                    <span class="text-xs font-medium text-white/50 line-clamp-2 text-center leading-tight">${article.title}</span>
                  </div>`
                : `<div class="w-full h-full bg-gradient-to-br from-zinc-600 to-zinc-800 flex items-center justify-center p-1">
                    <span class="text-xs font-medium text-white/50 line-clamp-2 text-center leading-tight">${article.title}</span>
                  </div>`
            }
          </a>
          
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-sm leading-snug line-clamp-1">
              <a href="/article/${article.id}" class="hover:text-indigo-400 transition-colors">
                ${article.title}
              </a>
            </h3>
            
            <div class="flex items-center gap-2 text-xs text-zinc-400 mt-1 flex-wrap">
              <span>${article.source}</span>
              <span>•</span>
              <time datetime="${article.pubDate}">${new Date(article.pubDate).toLocaleDateString('fr-FR', {
                day: 'numeric',
                month: 'long',
                year: 'numeric',
              })}</time>
              <span>•</span>
              <span>Ajouté le ${formattedAddedDate}</span>
            </div>
            
            <div class="flex flex-wrap gap-1 mt-1.5">
              ${article.categories
                .map(
                  (cat) => 
                    `<span class="px-1.5 py-0.5 text-[0.65rem] font-medium rounded-full border bg-zinc-500/20 text-zinc-400 border-zinc-500/30 hover:opacity-80 transition-opacity">${cat}</span>`
                )
                .join('')}
            </div>
          </div>
          
          <!-- Mark as read button -->
          <button 
            data-mark-as-read
            data-article-id="${article.id}"
            aria-label="Marquer comme lu"
            class="absolute bottom-3 right-3 px-3 py-1.5 text-xs rounded-lg bg-zinc-800 hover:bg-zinc-700 text-zinc-300 transition-colors"
          >
            Marquer lu
          </button>
        </article>
      `;
    }
    
    function setupMarkAsReadListener() {
      // Global event delegation for "Mark as read" buttons
      document.addEventListener('click', (e) => {
        if (e.target.closest('[data-mark-as-read]')) {
          const button = e.target.closest('[data-mark-as-read]');
          const articleId = button.getAttribute('data-article-id');
          
          if (articleId) {
            try {
              // Remove from read-later list
              removeFromReadLater(articleId);
              
              // Remove the article element from the DOM
              const articleElement = button.closest('article');
              if (articleElement) {
                articleElement.remove();
                
                // Check if no items left
                const container = document.getElementById('read-later-container');
                if (container && container.children.length === 0) {
                  document.getElementById('read-later-empty').classList.remove('hidden');
                }
                
                // Update header counter
                updateReadLaterCounter();
              }
            } catch (err) {
              console.error('Error marking as read:', err);
            }
          }
        }
      });
    }
    
    function updateReadLaterCounter() {
      try {
        const readLaterItems = getReadLaterSorted();
        const counterElements = document.querySelectorAll('[data-read-later-count]');
        counterElements.forEach(el => {
          el.textContent = readLaterItems.length.toString();
          el.style.display = readLaterItems.length > 0 ? 'inline-flex' : 'none';
        });
      } catch (e) {
        // Ignore localStorage errors
      }
    }
    
    // Initialize mark as read listener
    setupMarkAsReadListener();
  </script>
</Layout>